    {
      "name": "posY",
      "in": "query",
      "description": "해당 지점의 Y좌표(위도)",
      "required": false,
      "schema": {
        "type": "string",
        "description": "해당 지점의 Y좌표(위도)",
        "example": 37.402159
      },
      "example": 37.402159
    }
  ],
