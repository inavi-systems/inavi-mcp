        "minimum": 0,
        "type": "string",
        "description": "좌표 체계",
        "default": "1",
        "enum": [
          "0",
          "1"
        ],
        "x-enum-descriptions": {
          "0": "TW 좌표",
          "1": "WGS84 좌표"
        }
      },
      "x-enum-descriptions": {
        "0": "TW 좌표",
