      "schema": {
        "type": "string"
      }
    },
    {
      "name": "poiid",
      "in": "query",
      "description": "POI 고유 ID<br>*구분자(\",\") 와 함께 입력 가능<br>*예: 123,1234,234",
      "required": true,
      "schema": {
        "pattern": "^[0-9]+(\\s*,\\s*[0-9]+)*$",
        "type": "string",
        "description": "POI 고유 ID<br>*구분자(\",\") 와 함께 입력 가능<br>*예: 123,1234,234",
        "example": 8827198
      },
      "example": 8827198
    },
